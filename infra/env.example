# AI Audio Studio — Environment Configuration
# Copy to infra/.env and fill in all values. NEVER commit .env.

# ── Postgres ────────────────────────────────────────────────────────────
POSTGRES_DB=studiodb
POSTGRES_USER=studio
POSTGRES_PASSWORD=changeme_strong_password_here

# ── n8n ─────────────────────────────────────────────────────────────────
N8N_DB=n8ndb
N8N_USER=admin
N8N_PASSWORD=changeme_n8n_password_here
N8N_WEBHOOK_URL=http://localhost:5678
# Starter workflows are imported automatically the first time n8n boots.

# ── Network exposure ────────────────────────────────────────────────────
# Default to LAN exposure. Change to 127.0.0.1 for local-only access.
BIND_HOST=0.0.0.0
CONTROL_PLANE_HOST=studio-brain.local
CONTROL_PLANE_LAN_IP=192.168.1.153

# ── Ollama model selection ───────────────────────────────────────────────
# Planner: strong reasoning model for drafting and decision making
# Classifier: small fast model for routing and classification
# Embedding: for project memory and retrieval (optional)
OLLAMA_BASE_URL=http://host.docker.internal:11434
PLANNER_MODEL=qwen2.5:14b-instruct
CLASSIFIER_MODEL=qwen2.5:3b
CONCIERGE_LLM_TIMEOUT_SECONDS=120
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=30m

# LLM provider: ollama (local), anthropic, or openai
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Model name mappings when using commercial providers:
# Anthropic: PLANNER_MODEL=claude-sonnet-4-6  CLASSIFIER_MODEL=claude-haiku-4-5-20251001
# OpenAI:    PLANNER_MODEL=gpt-4o             CLASSIFIER_MODEL=gpt-4o-mini
# Ollama:    PLANNER_MODEL=qwen2.5:14b-instruct  CLASSIFIER_MODEL=qwen2.5:3b

# ── Gmail integration (inbox triage — READ-ONLY scope only) ─────────────
# OAuth 2.0 credentials from Google Cloud Console
# Scope: https://www.googleapis.com/auth/gmail.readonly
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Comma-separated Gmail label names to watch
ALLOWED_INBOX_LABELS=NeedsReply,Clients,Leads

# ── Email send credentials (separate from triage — SEND scope) ──────────
# Held ONLY by approved-send service. Requires human approval to use.
GMAIL_SEND_CLIENT_ID=
GMAIL_SEND_CLIENT_SECRET=
GMAIL_SEND_REFRESH_TOKEN=

# ── Social integrations (draft-only, no auto-post without approval) ──────
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# ── Shared volume paths ──────────────────────────────────────────────────
# These paths are used by the local Mac in `single_machine`.
# In `control_plane_plus_worker`, the worker Mac must mount the same paths or define PATH_TRANSLATION_JSON.
SHARED_PROJECTS_PATH=/Volumes/StudioShare/projects
DRAFT_QUEUE_PATH=/Volumes/StudioShare/draft-queue
APPROVAL_QUEUE_PATH=/Volumes/StudioShare/approval-queue
WATCHED_STEMS_PATH=/Volumes/StudioShare/incoming-stems
DELIVERY_PATH=/Volumes/StudioShare/deliveries

# ── Studio worker node (optional split-mode only) ────────────────────────
# Leave these unset/unused when running everything on one Mac.
MAC_MINI_BASE_URL=http://192.168.1.10
WORKER_SLUG=studio-mac
WORKER_DISPLAY_NAME=Studio Mac
WORKER_PLATFORM=macos
# Required for split deployments. Use the worker machine's reachable LAN URL.
WORKER_API_BASE_URL=http://192.168.1.20:8190
WORKER_CAPABILITIES=session-prep,revision-parser,delivery-packager
POLL_INTERVAL_SECONDS=10
STUDIO_WORKER_DRY_RUN_DAW=true
LOCAL_WORKER_SLUG=local-studio-worker
LOCAL_WORKER_DISPLAY_NAME=Local Studio Worker
LOCAL_WORKER_CAPABILITIES=session-prep,revision-parser,delivery-packager,execute-soundflow,execute-reascript
# Optional workstation discovery / DAW paths. Keep macOS bundles for Mac workers;
# Windows workers should point at .exe paths and explicit mount translations.
REAPER_BINARY_PATH=/Applications/REAPER.app/Contents/MacOS/REAPER
PROTOOLS_APP_PATH=/Applications/Pro Tools.app
SOUNDFLOW_CLI_PATH=/Applications/SoundFlow.app/Contents/MacOS/SoundFlow
WAVELAB_APP_PATH=
# Optional prefix mappings if the studio Mac mounts the same share at a different path
PATH_TRANSLATION_JSON={}

# ── Studio identity (used in prompt templates — make it yours) ───────────
STUDIO_NAME=Your Studio Name
ENGINEER_NAME=Your Name
# Default automation depth for new projects: 1=import-only 2=+qc 3=+mix-plan 4=full
DEFAULT_EFFORT_LEVEL=2
# Describe your communication style for AI drafts (1-2 sentences)
ENGINEER_VOICE=Warm, direct, and professional. Values clear timelines. Responds like a craftsperson, not a salesperson.
# Comma-separated list of X-Actor values allowed to approve/reject jobs in the queue
AUTHORIZED_ACTORS=owner,engineer
OPERATOR_API_TOKEN=change-me-operator-token
WORKER_API_TOKEN=change-me-worker-token

# ── Alerts and escalation hooks ──────────────────────────────────────────
# Dashboard alerts are always on. Add webhook/email targets when ready.
ALERT_WEBHOOK_URL=
ALERT_EMAIL_TO=

# ── Safety policy ────────────────────────────────────────────────────────
# strict = all approval checks enforced; permissive = warnings only (never use in production)
POLICY_ENFORCEMENT=strict
# Max time (hours) a draft may sit in queue before auto-expiring (not auto-sending)
MAX_DRAFT_AGE_HOURS=48
