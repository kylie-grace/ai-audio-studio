            "index": 0
          }
        ]
      ]
    },
    "Assemble Runtime Alert Digest": {
      "main": [
        [
          {
            "node": "Respond Runtime Alert Digest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
