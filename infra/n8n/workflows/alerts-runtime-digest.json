      "typeVersion": 4.2,
      "position": [
        480,
        280
      ]
    },
    {
      "parameters": {
        "mode": "manual",
        "jsonOutput": "={\"received_event\": $(\"Inbound Alert Webhook\").item.json.body ?? {}, \"runtime_summary\": $json, \"received_at\": $now}"
