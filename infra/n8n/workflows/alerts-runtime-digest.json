      "position": [
        740,
        280
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {}
      },
      "id": "Respond_RuntimeAlertDigest",
      "name": "Respond Runtime Alert Digest",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        1000,
        280
      ]
    }
  ],
  "connections": {
